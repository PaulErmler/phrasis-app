#!/bin/sh
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'post-checkout' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs post-checkout "$@"

# Only run on branch checkouts, not file checkouts
if [ "$3" != "1" ]; then
  exit 0
fi

CURR_BRANCH=$(git rev-parse --abbrev-ref HEAD | tr '/' '_')
SNAPSHOT_DIR=".convex-snapshots"
SNAPSHOT="$SNAPSHOT_DIR/${CURR_BRANCH}.zip"

if [ ! -f "$SNAPSHOT" ]; then
  printf "\n[convex] No snapshot for branch '%s' — keeping current data state.\n\n" "$CURR_BRANCH"
  exit 0
fi

printf "\n[convex] Restoring snapshot for branch '%s'...\n" "$CURR_BRANCH"
if ./node_modules/.bin/convex import --replace -y --env-file .env.local "$SNAPSHOT" 2>/dev/null; then
  printf "[convex] Snapshot restored successfully.\n\n"
else
  printf "[convex] Warning: snapshot restore failed (is the local Convex instance running?).\n\n"
fi
